.page {
  height: 100vh;
  background: #f6f6f8;
}

.hero {
  text-align: center;
  padding: 44rpx 28rpx 10rpx;
}

.hero-icon-wrap {
  margin: 0 auto;
  width: 104rpx;
  height: 104rpx;
  border-radius: 999px;
  background: rgba(17, 82, 212, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 22rpx;
}

.hero-icon {
  font-size: 54rpx;
}

.hero-title {
  font-size: 50rpx;
  font-weight: 800;
  color: #0f172a;
  letter-spacing: -0.02em;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #475569;
}

.main-action {
  padding: 22rpx 28rpx 6rpx;
}

.primary-btn {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  border-radius: 20rpx;
  background: #1152d4;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 38rpx rgba(17, 82, 212, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.primary-btn-icon {
  font-size: 32rpx;
}

.disclaimer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 30rpx;
}

.disclaimer-icon {
  flex-shrink: 0;
}

.hint {
  font-size: 24rpx;
  color: #64748b;
}

.hint-secondary {
  text-align: center;
  margin: 10rpx 0 20rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.section {
  padding: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.loading {
  padding: 32rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #64748b;
}

.load-error {
  padding: 32rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #dc2626;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.link-btn {
  background: transparent;
  color: #1152d4;
  font-size: 26rpx;
  padding: 0 10rpx;
  margin: 0;
  align-self: flex-end;
  margin-left: auto;
  text-align: right;
}

.card {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  border: 1px solid rgba(15, 23, 42, 0.06);
}

.section .card-horizontal {
  margin-bottom: 18rpx;
}

/* 最近作品卡片：左图右文（原型） */
.card-horizontal {
  display: flex;
  flex-direction: row;
  padding: 0;
  overflow: hidden;
}

.card-cover {
  width: 32%;
  min-width: 180rpx;
  aspect-ratio: 1;
  flex-shrink: 0;
  background: rgba(17, 82, 212, 0.08);
}

.card-cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 82, 212, 0.08);
}

.card-cover-emoji {
  font-size: 56rpx;
}

.card-cover-img {
  width: 100%;
  height: 100%;
}

.card-body {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.card-title-single {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #475569;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-meta {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #94a3b8;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
  text-align: right;
}

.dot {
  opacity: 0.6;
}

.card-cta {
  margin-top: 18rpx;
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: rgba(17, 82, 212, 0.10);
  color: #1152d4;
  font-size: 28rpx;
  font-weight: 700;
}

.empty {
  background: rgba(255, 255, 255, 0.65);
  border-radius: 22rpx;
  padding: 32rpx 26rpx;
  border: 1px dashed rgba(15, 23, 42, 0.18);
}

.empty-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.empty-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999px;
  border: 2px dashed rgba(15, 23, 42, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.empty-icon {
  font-size: 40rpx;
  color: #64748b;
  font-weight: 300;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.secondary-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1px solid rgba(15, 23, 42, 0.10);
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
}

/* 创建新故事卡片（参考原型 index.html：虚线框 + add 图标） */
.create-card {
  margin: 24rpx 0 30rpx;
  background: rgba(248, 250, 252, 0.8);
  border-radius: 22rpx;
  border: 2px dashed rgba(15, 23, 42, 0.15);
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.create-card-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.create-card-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999px;
  border: 2px dashed rgba(15, 23, 42, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.create-card-icon {
  font-size: 36rpx;
  color: #64748b;
  font-weight: 300;
}

.create-card-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748b;
}

/* 底部 Tab 栏（与原型一致） */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1px solid rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-around;
  z-index: 100;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 32rpx;
}

.tabbar-icon {
  font-size: 40rpx;
}

.tabbar-label {
  font-size: 22rpx;
  color: #64748b;
}

.tabbar-item-active .tabbar-label {
  color: #1152d4;
  font-weight: 700;
}

.spacer {
  height: 140rpx;
}
