.page {
  min-height: 100vh;
  background: #f6f6f8;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

.loading {
  padding: 40rpx 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
}

.load-error {
  padding: 40rpx 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: #dc2626;
}

.list {
  margin-top: 20rpx;
  height: 100vh;
  padding: 0 28rpx 40rpx;
  box-sizing: border-box;
  width: 100%;
}

.list .card {
  box-sizing: border-box;
  width: 100%;
}

.card {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1px solid rgba(15, 23, 42, 0.06);
}

/* 与首页一致的左图右文卡片 */
.card-horizontal {
  display: flex;
  flex-direction: row;
  padding: 0;
  overflow: hidden;
}

.card-cover {
  width: 32%;
  min-width: 180rpx;
  aspect-ratio: 1;
  flex-shrink: 0;
  background: rgba(17, 82, 212, 0.08);
}

.card-cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 82, 212, 0.08);
}

.card-cover-emoji {
  font-size: 56rpx;
}

.card-cover-img {
  width: 100%;
  height: 100%;
}

.card-body {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.card-title-single {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #475569;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-meta {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #94a3b8;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
  text-align: right;
}

.dot {
  opacity: 0.6;
}

.empty {
  padding: 60rpx 0;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
}

.primary {
  margin-top: 24rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  background: #1152d4;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

.spacer {
  height: 40rpx;
}
