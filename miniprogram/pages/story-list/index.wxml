<view class="page">
  <view class="loading" wx:if="{{loading}}">加载中…</view>
  <view class="load-error" wx:if="{{!loading && loadError}}">{{loadError}}</view>

  <scroll-view wx:if="{{!loading && !loadError}}" class="list" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" scroll-with-animation>
    <!-- 与首页一致的左图右文卡片 -->
    <view
      class="card card-horizontal"
      wx:for="{{list}}"
      wx:key="id"
      data-id="{{item.id}}"
      data-item="{{item}}"
      bindtap="openDetail"
    >
      <view class="card-cover">
        <image wx:if="{{item.coverUrl}}" class="card-cover-img" src="{{item.coverUrl}}" mode="aspectFill"/>
        <view wx:else class="card-cover-placeholder">
          <text class="card-cover-emoji">📖</text>
        </view>
      </view>
      <view class="card-body">
        <view class="card-title card-title-single">{{item.topic}}</view>
        <view class="card-desc">{{item.outlineShort}}</view>
        <view class="card-bottom">
          <view class="card-meta">
            <text>{{item.charCount}} 字符</text>
            <text class="dot">•</text>
            <text>{{item.sceneCount}} 幅插画</text>
          </view>
          <view class="card-time">{{item.updatedAtText}}</view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{list.length === 0}}">
      <view class="empty-title">还没有作品</view>
      <view class="empty-desc">去创作你的第一本连环画吧</view>
      <button class="primary" bindtap="goCreate">开始创作</button>
    </view>
    <view class="spacer"></view>
  </scroll-view>
</view>
